<Application x:Class="RamAI.Phase4.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Pas de StartupUri — le démarrage est géré dans App.xaml.cs -->
    <Application.Resources>
        <!-- Icône appliquée automatiquement à toutes les fenêtres de l'application -->
        <Style TargetType="Window">
            <Setter Property="Icon" Value="/Assets/RAM-AI.ico"/>
        </Style>
    </Application.Resources>
</Application>
