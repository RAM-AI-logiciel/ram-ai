<Window x:Class="RamAI.Phase4.Views.AverageReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RAM-AI — Rapport moyen des sessions"
        Width="480" Height="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0D1117"
        Foreground="#E6EDF3"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,14"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#388BFD"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,16,0,8"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"      Value="#21262D"/>
            <Setter Property="Foreground"      Value="#E6EDF3"/>
            <Setter Property="BorderBrush"     Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="18,8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#30363D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="📊  Rapport moyen des sessions"
                       FontSize="16" FontWeight="Bold" Foreground="#E6EDF3"/>
            <TextBlock FontSize="12" Foreground="#8B949E" Margin="0,4,0,0">
                <Run Text="{Binding SessionCount, StringFormat={}{0} session(s) enregistrée(s)}"/>
            </TextBlock>
            <Rectangle Height="1" Fill="#30363D" Margin="0,12,0,0"/>
        </StackPanel>

        <!-- Pas de données -->
        <TextBlock Grid.Row="1"
                   Text="Aucune session enregistrée.&#x0a;Lancez le dashboard et cliquez sur « Rapport » pour enregistrer votre première session."
                   Visibility="{Binding NoDataVisibility}"
                   Foreground="#8B949E" FontSize="13" TextWrapping="Wrap"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextAlignment="Center"/>

        <!-- Données -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding DataVisibility}">
            <StackPanel>
                <!-- Moyennes -->
                <TextBlock Text="MOYENNES PAR SESSION" Style="{StaticResource SectionHeader}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Durée moyenne" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding AvgDurationText}" Style="{StaticResource ValueStyle}"/>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="RAM récupérée / session" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AvgRamFreedText}" Style="{StaticResource ValueStyle}" Foreground="#3FB950"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="RAM récupérée / heure" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding AvgRamFreedPerHourText}" Style="{StaticResource ValueStyle}" Foreground="#3FB950"/>

                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Processus optimisés (moy.)" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding AvgProcessesText}" Style="{StaticResource ValueStyle}" Foreground="#79C0FF"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Mode le plus utilisé" Style="{StaticResource LabelStyle}" Grid.ColumnSpan="2"/>
                </Grid>
                <TextBlock Text="{Binding TopModeText}" Style="{StaticResource ValueStyle}" Foreground="#D4AF37"/>

                <!-- Totaux -->
                <Rectangle Height="1" Fill="#30363D" Margin="0,4,0,0"/>
                <TextBlock Text="TOTAUX CUMULÉS — TOUTES SESSIONS" Style="{StaticResource SectionHeader}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="RAM récupérée (total)" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding TotalRamFreedText}" Style="{StaticResource ValueStyle}" Foreground="#3FB950"/>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Processus optimisés (total)" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TotalProcessesText}" Style="{StaticResource ValueStyle}" Foreground="#79C0FF"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Boutons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="💾 Exporter .txt"
                    Style="{StaticResource ActionBtn}"
                    Command="{Binding ExportReportCommand}"
                    Margin="0,0,8,0"/>
            <Button Content="Fermer"
                    Style="{StaticResource ActionBtn}"
                    IsCancel="True"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
