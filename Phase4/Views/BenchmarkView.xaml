<UserControl x:Class="RamAI.Phase4.Views.BenchmarkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="#0D1117">

    <UserControl.Resources>
        <!-- Bouton standard (reprend le style de MainWindow) -->
        <Style x:Key="BBtn" TargetType="Button">
            <Setter Property="Background"      Value="#21262D"/>
            <Setter Property="Foreground"      Value="#E6EDF3"/>
            <Setter Property="BorderBrush"     Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#30363D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#8B949E"/>
                                <Setter Property="Background" Value="#161B22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20,10,20,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>   <!-- barre d'outils -->
            <RowDefinition Height="3"/>    <!-- barre de progression -->
            <RowDefinition Height="Auto"/> <!-- métriques (2 × 4 cartes) -->
            <RowDefinition Height="*"/>    <!-- graphique + historique -->
        </Grid.RowDefinitions>

        <!-- ── Row 0 : titre + statut + boutons ─────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Benchmarks" FontSize="15" FontWeight="Bold"
                           Foreground="#E6EDF3"/>
                <TextBlock Text="{Binding StatusText}" FontSize="10"
                           Foreground="#8B949E" Margin="0,1,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Annuler (visible uniquement pendant la mesure) -->
                <Button Content="⏹ Annuler" Command="{Binding CancelBenchmarkCommand}"
                        Foreground="#E94560" Margin="0,0,6,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource BBtn}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Lancer / En cours -->
                <Button Command="{Binding LaunchBenchmarkCommand}" Margin="0,0,6,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content"         Value="▶  Lancer benchmark  (60 s)"/>
                            <Setter Property="Background"      Value="#238636"/>
                            <Setter Property="Foreground"      Value="#E6EDF3"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding"         Value="14,6"/>
                            <Setter Property="FontSize"        Value="12"/>
                            <Setter Property="Cursor"          Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2EA043"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#21262D"/>
                                                <Setter Property="Foreground" Value="#8B949E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Content" Value="⏳  En cours…"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Exporter -->
                <Button Content="📥  Exporter rapport"
                        Command="{Binding ExportReportCommand}"
                        Style="{StaticResource BBtn}"/>
            </StackPanel>
        </Grid>

        <!-- ── Row 1 : barre de progression ──────────────────────────────────── -->
        <ProgressBar Grid.Row="1"
                     Value="{Binding ProgressValue}" Maximum="100"
                     Background="#21262D" Foreground="#388BFD"
                     BorderThickness="0">
            <ProgressBar.Style>
                <Style TargetType="ProgressBar">
                    <Setter Property="Visibility" Value="Hidden"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ProgressBar.Style>
        </ProgressBar>

        <!-- ── Row 2 : cartes métriques (2 lignes × 4 colonnes) ──────────────── -->
        <UniformGrid Grid.Row="2" Rows="2" Columns="4" Margin="0,8,0,8">

            <!-- Ligne 1 : métriques globales -->
            <Border Margin="0,0,6,5" Background="#161B22" BorderBrush="#30363D"
                    BorderThickness="1" CornerRadius="8" Padding="12,7">
                <StackPanel>
                    <TextBlock Text="RAM totale système" FontSize="10" Foreground="#8B949E"/>
                    <TextBlock Text="{Binding RamTotalText}" FontSize="18" FontWeight="Bold"
                               Foreground="#E6EDF3" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <Border Margin="0,0,6,5" Background="#161B22" BorderBrush="#30363D"
                    BorderThickness="1" CornerRadius="8" Padding="12,7">
                <StackPanel>
                    <TextBlock Text="RAM utilisée (snapshot)" FontSize="10" Foreground="#8B949E"/>
                    <TextBlock Text="{Binding RamBeforeText}" FontSize="18" FontWeight="Bold"
                               Foreground="#D29922" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <Border Margin="0,0,6,5" Background="#0A1F12" BorderBrush="#238636"
                    BorderThickness="1" CornerRadius="8" Padding="12,7">
                <StackPanel>
                    <TextBlock Text="RAM libérée (session)" FontSize="10" Foreground="#8B949E"/>
                    <TextBlock Text="{Binding RamFreedText}" FontSize="18" FontWeight="Bold"
                               Foreground="#3FB950" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <Border Margin="0,0,0,5" Background="#161B22" BorderBrush="#30363D"
                    BorderThickness="1" CornerRadius="8" Padding="12,7">
                <StackPanel>
                    <TextBlock Text="Processus optimisés" FontSize="10" Foreground="#8B949E"/>
                    <TextBlock Text="{Binding ProcessesText}" FontSize="18" FontWeight="Bold"
                               Foreground="#79C0FF" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <!-- Ligne 2 : mode + cycle + par-mode -->
            <Border Margin="0,0,6,0" Background="#161B22" BorderBrush="#30363D"
                    BorderThickness="1" CornerRadius="8" Padding="12,7">
                <StackPanel>
                    <TextBlock Text="Mode actif" FontSize="10" Foreground="#8B949E"/>
                    <TextBlock Text="{Binding ActiveModeText}" FontSize="18" FontWeight="Bold"
                               Foreground="#C084FC" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <Border Margin="0,0,6,0" Background="#161B22" BorderBrush="#30363D"
                    BorderThickness="1" CornerRadius="8" Padding="12,7">
                <StackPanel>
                    <TextBlock Text="Temps moy. / cycle" FontSize="10" Foreground="#8B949E"/>
                    <TextBlock Text="{Binding AvgCycleText}" FontSize="18" FontWeight="Bold"
                               Foreground="#E6EDF3" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <Border Margin="0,0,6,0" Background="#1F1300" BorderBrush="#D29922"
                    BorderThickness="1" CornerRadius="8" Padding="12,7">
                <StackPanel>
                    <TextBlock Text="🎮 Gaming libéré" FontSize="10" Foreground="#8B949E"/>
                    <TextBlock Text="{Binding GamingFreedText}" FontSize="16" FontWeight="Bold"
                               Foreground="#D29922" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <Border Margin="0,0,0,0" Background="#1A0A2E" BorderBrush="#7C3AED"
                    BorderThickness="1" CornerRadius="8" Padding="12,7">
                <StackPanel>
                    <TextBlock Text="🤖 IA libéré" FontSize="10" Foreground="#8B949E"/>
                    <TextBlock Text="{Binding IaFreedText}" FontSize="16" FontWeight="Bold"
                               Foreground="#C084FC" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ── Row 3 : graphique + historique ────────────────────────────────── -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="264"/>
            </Grid.ColumnDefinitions>

            <!-- Graphique LiveCharts -->
            <Border Grid.Column="0" Background="#161B22" BorderBrush="#30363D"
                    BorderThickness="1" CornerRadius="8" Padding="8,6">
                <Grid>
                    <TextBlock Text="Évolution RAM libérée — historique des sessions"
                               FontSize="10" Foreground="#8B949E"
                               HorizontalAlignment="Left" VerticalAlignment="Top"/>

                    <!-- Placeholder quand pas encore de données -->
                    <TextBlock Text="Aucune session enregistrée — lancez un premier benchmark."
                               FontSize="12" Foreground="#6E7681"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Series.Length}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <lvc:CartesianChart Series="{Binding Series}"
                                        XAxes="{Binding XAxes}"
                                        YAxes="{Binding YAxes}"
                                        Margin="0,18,0,0"
                                        Background="Transparent"
                                        TooltipPosition="Top"/>
                </Grid>
            </Border>

            <!-- Historique sessions -->
            <Border Grid.Column="2" Background="#161B22" BorderBrush="#30363D"
                    BorderThickness="1" CornerRadius="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Historique des sessions"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#8B949E" Margin="12,8,12,4"/>

                    <!-- Aucune session -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="Aucune session encore."
                               FontSize="11" Foreground="#6E7681"
                               HorizontalAlignment="Center" Margin="0,20,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Sessions.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Sessions}" Margin="0,0,0,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="8,2" Padding="8,6"
                                            Background="#0D1117" CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding StartTime, StringFormat={}{0:dd/MM/yy HH:mm}}"
                                                           FontSize="11" Foreground="#8B949E"/>
                                                <TextBlock FontSize="10"
                                                           Foreground="#6E7681" Margin="0,2,0,0">
                                                    <Run Text="{Binding ActiveMode}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding ProcessesOptimized, StringFormat={}{0:N0} proc.}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding DurationLabel}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding TotalRamFreedGb, StringFormat={}{0:F2} Go}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="#3FB950"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
