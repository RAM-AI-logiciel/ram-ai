<Window x:Class="RamAI.Phase4.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RAM-AI — Licence"
        Width="520" Height="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        Foreground="#E6EDF3"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="TierCard" TargetType="Border">
            <Setter Property="Background"      Value="#161B22"/>
            <Setter Property="BorderBrush"     Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="Margin"          Value="4,0"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"   Value="#238636"/>
            <Setter Property="Foreground"   Value="#E6EDF3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="20,8"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2EA043"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button"
               BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#21262D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Titre -->
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>   <!-- Saisie clé -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>   <!-- Message validation -->
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>   <!-- Tableau paliers -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>   <!-- Boutons -->
        </Grid.RowDefinitions>

        <!-- Titre -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <Ellipse Width="40" Height="40" Fill="#388BFD"
                     HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="RAM-AI" FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Entrez votre clé de licence" FontSize="13"
                       Foreground="#8B949E" HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Saisie clé -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding KeyInput, UpdateSourceTrigger=PropertyChanged}"
                     Background="#161B22" Foreground="#E6EDF3"
                     BorderBrush="#388BFD" BorderThickness="1"
                     Padding="10,8" FontSize="14" FontFamily="Consolas"
                     CaretBrush="#E6EDF3"
                     VerticalContentAlignment="Center"
                     Margin="0,0,8,0">
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>

            <Button Grid.Column="1" Content="Valider"
                    Style="{StaticResource PrimaryBtn}"
                    Command="{Binding ValidateKeyCommand}"/>
        </Grid>

        <!-- Message validation -->
        <TextBlock Grid.Row="4"
                   Text="{Binding ValidationMessage}"
                   FontSize="12" HorizontalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="#E94560"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsValid}" Value="True">
                            <Setter Property="Foreground" Value="#3FB950"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Tableau paliers -->
        <Border Grid.Row="6" Background="#161B22"
                BorderBrush="#30363D" BorderThickness="1" CornerRadius="8"
                Padding="0,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- En-têtes -->
                <Grid Grid.Row="0" Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Palier"      Foreground="#8B949E" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Format clé"  Foreground="#8B949E" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Cache virtuel" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="Description" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center"/>
                </Grid>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding Tiers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="12,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}"
                                           Foreground="#E6EDF3" FontWeight="SemiBold" FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Format}"
                                           Foreground="#388BFD" FontFamily="Consolas" FontSize="11"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding CacheLimit}"
                                           Foreground="#D29922" FontSize="11"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding Description}"
                                           Foreground="#8B949E" FontSize="11"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- Boutons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal"
                    HorizontalAlignment="Center">

            <!-- "Effacer" et "Fermer" : visibles seulement si une licence est active -->
            <Button Content="Effacer la licence"
                    Command="{Binding ClearLicenseCommand}"
                    Margin="0,0,12,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryBtn}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsValid}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="Fermer"
                    Click="CloseButton_Click"
                    Margin="0,0,12,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryBtn}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsValid}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- "Quitter" : toujours visible — seul moyen de sortir sans clé -->
            <Button Content="Quitter RAM-AI"
                    Style="{StaticResource SecondaryBtn}"
                    Click="QuitButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
