<Window x:Class="RamAI.Phase4.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RAM-AI — Memory Intelligence"
        Width="1100" Height="460"
        MinWidth="1100" MinHeight="380"
        Background="#0D1117"
        Foreground="#E6EDF3"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Bouton toolbar standard -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background"      Value="#21262D"/>
            <Setter Property="Foreground"      Value="#E6EDF3"/>
            <Setter Property="BorderBrush"     Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#30363D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bouton Gaming (orange actif / gris inactif) -->
        <Style x:Key="GamingBtn" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ForceGamingMode}" Value="True">
                    <Setter Property="Background"  Value="#D29922"/>
                    <Setter Property="BorderBrush" Value="#E3B341"/>
                    <Setter Property="Foreground"  Value="#0D1117"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ForceGamingMode}" Value="False">
                    <Setter Property="Background"  Value="#21262D"/>
                    <Setter Property="BorderBrush" Value="#30363D"/>
                    <Setter Property="Foreground"  Value="#8B949E"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Badge licence -->
        <Style x:Key="LicenseBadge" TargetType="Border">
            <Setter Property="Background"      Value="#1C2128"/>
            <Setter Property="BorderBrush"     Value="#388BFD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="8,3"/>
        </Style>

        <!-- Carte métrique principale -->
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background"      Value="#161B22"/>
            <Setter Property="BorderBrush"     Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="36,22"/>
            <Setter Property="Margin"          Value="0,0,14,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- Row 0 : Header -->
            <RowDefinition Height="Auto"/> <!-- Row 1 : Bannière Gaming -->
            <RowDefinition Height="Auto"/> <!-- Row 2 : Bannière Anti-Swap -->
            <RowDefinition Height="Auto"/> <!-- Row 3 : Bannière Mode Éco -->
            <RowDefinition Height="*"/>    <!-- Row 4 : Contenu principal centré -->
            <RowDefinition Height="30"/>   <!-- Row 5 : Status bar -->
            <RowDefinition Height="Auto"/> <!-- Row 6 : Bandeau bêta (masqué si pas bêta) -->
        </Grid.RowDefinitions>

        <!-- ── Row 0 : Header ────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#161B22"
                BorderBrush="#30363D" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + titre -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse Width="28" Height="28" Fill="#388BFD" Margin="0,0,10,0"/>
                    <TextBlock Text="RAM-AI" FontSize="18" FontWeight="Bold"
                               Foreground="#E6EDF3" VerticalAlignment="Center"/>
                    <TextBlock Text="  Memory Intelligence" FontSize="12"
                               Foreground="#8B949E" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Contrôles à droite — ordre : Badge Ultra | Licence | ▶ | ■ | Turbo | Tournoi | VRAM | Forcer Gaming -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,6,0">

                    <!-- 1. Badge licence : violet/doré si Ultra, bleu sinon -->
                    <Border Margin="0,0,6,0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource LicenseBadge}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUltraModeActive}" Value="True">
                                        <Setter Property="BorderBrush" Value="#7C3AED"/>
                                        <Setter Property="Background"  Value="#1A0A2E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="11">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="⬡ "/>
                                        <Setter Property="Foreground" Value="#388BFD"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUltraModeActive}" Value="True">
                                                <Setter Property="Text"       Value="★ "/>
                                                <Setter Property="Foreground" Value="#C084FC"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding LicenseTierLabel}" FontSize="11">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#388BFD"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUltraModeActive}" Value="True">
                                                <Setter Property="Foreground" Value="#C084FC"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text=" — " Foreground="#8B949E" FontSize="11"/>
                            <TextBlock Text="{Binding LicenseCacheLabel}" FontSize="11">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#8B949E"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUltraModeActive}" Value="True">
                                                <Setter Property="Foreground" Value="#D4AF37"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 2. Licence -->
                    <Button Content="🔑 Licence"
                            Style="{StaticResource ToolBtn}"
                            Command="{Binding OpenLicenseCommand}"
                            Margin="0,0,4,0"/>

                    <!-- 4. Démarrer service -->
                    <Button Content="▶"
                            Style="{StaticResource ToolBtn}"
                            Command="{Binding StartServiceCommand}"
                            Foreground="#3FB950" Margin="0,0,3,0"
                            ToolTip="Démarrer le service Phase 3"/>

                    <!-- 5. Arrêter service -->
                    <Button Content="■"
                            Style="{StaticResource ToolBtn}"
                            Command="{Binding StopServiceCommand}"
                            Foreground="#E94560" Margin="0,0,4,0"
                            ToolTip="Arrêter le service Phase 3"/>

                    <!-- 6. Turbo -->
                    <Button Content="⚡ Turbo"
                            Style="{StaticResource ToolBtn}"
                            Command="{Binding TurboCommand}"
                            Foreground="#E94560"
                            ToolTip="Optimisation Turbo : vide le working set de TOUS les processus en une passe"
                            Margin="0,0,4,0"/>

                    <!-- 7. Mode Tournoi — Ultra uniquement -->
                    <Button Command="{Binding ToggleTournamentModeCommand}"
                            Margin="0,0,4,0"
                            ToolTip="Mode Tournoi Ultra : 500ms, priorité BelowNormal, éviction progressive"
                            Visibility="{Binding IsUltraModeActive, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToolBtn}">
                                <Setter Property="Content"    Value="🏆 Tournoi"/>
                                <Setter Property="Foreground" Value="#C084FC"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTournamentModeActive}" Value="True">
                                        <Setter Property="Content"    Value="🏆 ON"/>
                                        <Setter Property="Foreground" Value="#D4AF37"/>
                                        <Setter Property="Background" Value="#1A0A2E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- 8. Indicateur VRAM — Ultra uniquement -->
                    <TextBlock Text="{Binding VramInfoText}"
                               FontSize="10" Foreground="#7C3AED"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               Visibility="{Binding IsUltraModeActive, Converter={StaticResource BoolToVis}}"/>

                    <!-- 9. Forcer Gaming -->
                    <Button Style="{StaticResource GamingBtn}"
                            Command="{Binding ToggleForceGamingModeCommand}"
                            ToolTip="Forcer / désactiver le Mode Gaming manuellement"
                            Margin="0,0,4,0">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎮 " FontSize="11"/>
                                <TextBlock FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Gaming"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ForceGamingMode}" Value="True">
                                                    <Setter Property="Text" Value="Gaming ✓"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <!-- 10. Forcer Éco -->
                    <Button Command="{Binding ToggleForceEcoModeCommand}"
                            ToolTip="Forcer / désactiver le Mode Éco manuellement">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToolBtn}">
                                <Setter Property="Foreground" Value="#4ADE80"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ForceEcoMode}" Value="True">
                                        <Setter Property="Background" Value="#0A2A0A"/>
                                        <Setter Property="Foreground" Value="#86EFAC"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔋 " FontSize="11"/>
                                <TextBlock FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Éco"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ForceEcoMode}" Value="True">
                                                    <Setter Property="Text" Value="Éco ✓"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Row 1 : Bannière Mode Gaming ──────────────────────────────── -->
        <Border Grid.Row="1"
                Visibility="{Binding IsGamingModeActive, Converter={StaticResource BoolToVis}}"
                Padding="0,10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#C0392B" Offset="0.0"/>
                                <GradientStop Color="#E67E22" Offset="0.5"/>
                                <GradientStop Color="#C0392B" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ForceGamingMode}" Value="True">
                            <Setter Property="Background" Value="#D29922"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Ellipse Width="10" Height="10" Fill="White"
                         VerticalAlignment="Center" Margin="0,0,10,0">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1" To="0.2" Duration="0:0:0.7"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>

                <TextBlock FontSize="14" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="MODE GAMING ACTIF"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ForceGamingMode}" Value="True">
                                    <Setter Property="Text" Value="MODE GAMING FORCÉ"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Text=" — " FontSize="14" Foreground="#FFE0A0"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ForceGamingMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding DetectedGameName}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#FFE0A0" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ForceGamingMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Text="  •  Intervalle 500 ms  •  Éviction agressive"
                           FontSize="11" Foreground="#FFD0A0"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── Row 2 : Bannière Anti-Swap ──────────────────────────────────── -->
        <Border Grid.Row="2" Padding="0,7"
                Visibility="{Binding IsAntiSwapActive, Converter={StaticResource BoolToVis}}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#7F1D1D" Offset="0.0"/>
                    <GradientStop Color="#991B1B" Offset="0.5"/>
                    <GradientStop Color="#7F1D1D" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Ellipse Width="9" Height="9" Fill="#FCA5A5"
                         VerticalAlignment="Center" Margin="0,0,9,0">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1" To="0.2" Duration="0:0:0.5"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <TextBlock Text="ANTI-SWAP ACTIF" FontSize="13" FontWeight="Bold"
                           Foreground="#FCA5A5" VerticalAlignment="Center"/>
                <TextBlock Text=" — Intervalle 500 ms  •  " FontSize="11"
                           Foreground="#FECACA" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <TextBlock Text="{Binding SwapPagesPerSec, StringFormat={}{0:F0} pages/s}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#FEF2F2" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Row 3 : Bannière Mode Éco ────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#0A1A0A" Padding="0,6"
                Visibility="{Binding IsEcoModeActive, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="🔋 " FontSize="13" VerticalAlignment="Center"/>
                <TextBlock Text="MODE ÉCO ACTIF" FontSize="13" FontWeight="Bold"
                           Foreground="#4ADE80" VerticalAlignment="Center"/>
                <TextBlock FontSize="10" Foreground="#166534"
                           VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value=" — sur batterie  •  Intervalles réduits  •  Impact CPU minimal"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ForceEcoMode}" Value="True">
                                    <Setter Property="Text" Value=" — Mode Éco forcé manuellement  •  Intervalles réduits"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── Row 4 : Contenu principal ─────────────────────────────────── -->
        <Grid Grid.Row="4">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <TextBlock Text="RAM PHYSIQUE UTILISÉE"
                           FontSize="12" FontWeight="SemiBold" Foreground="#8B949E"
                           HorizontalAlignment="Center" Margin="0,0,0,22"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <!-- RAM utilisée actuellement -->
                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentRamUsedGb, StringFormat={}{0:F1} Go}"
                                       FontSize="54" FontWeight="Bold"
                                       Foreground="#E6EDF3"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="utilisée actuellement"
                                       FontSize="12" Foreground="#6E7681"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Amélioration en % depuis le lancement -->
                    <Border Background="#0A1F12" BorderThickness="1" CornerRadius="12"
                            Padding="36,22" Margin="0">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#238636"/>
                        </Border.BorderBrush>
                        <StackPanel>
                            <TextBlock Text="{Binding ImprovementText}"
                                       FontSize="54" FontWeight="Bold"
                                       Foreground="#3FB950"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="depuis le lancement"
                                       FontSize="12" Foreground="#6E7681"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Métriques secondaires -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,28,0,0">

                    <StackPanel Margin="0,0,60,0">
                        <TextBlock Text="{Binding TotalRamFreedGb, StringFormat={}{0:F1} Go}"
                                   FontSize="24" FontWeight="SemiBold"
                                   Foreground="#3FB950" HorizontalAlignment="Center"/>
                        <TextBlock Text="RAM récupérée depuis les processus"
                                   FontSize="11" Foreground="#8B949E"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Rectangle Width="1" Fill="#30363D" Margin="0,4,60,4"/>

                    <StackPanel>
                        <TextBlock Text="{Binding ProcessesOptimized, StringFormat={}{0:N0}}"
                                   FontSize="24" FontWeight="SemiBold"
                                   Foreground="#79C0FF" HorizontalAlignment="Center"/>
                        <TextBlock Text="processus optimisés"
                                   FontSize="11" Foreground="#8B949E"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Badge état gaming -->
                <Border HorizontalAlignment="Center" Margin="0,18,0,0"
                        CornerRadius="6" Padding="14,6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility"      Value="Visible"/>
                            <Setter Property="Background"      Value="#1C2A1C"/>
                            <Setter Property="BorderBrush"     Value="#3FB950"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DetectedGameLabel}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ForceGamingMode}" Value="True">
                                    <Setter Property="Background"  Value="#2A1F0A"/>
                                    <Setter Property="BorderBrush" Value="#D29922"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding DetectedGameLabel}"
                               FontSize="12" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#3FB950"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ForceGamingMode}" Value="True">
                                        <Setter Property="Foreground" Value="#D29922"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

            </StackPanel>
        </Grid>

        <!-- ── Row 5 : Status bar ─────────────────────────────────────────── -->
        <Border Grid.Row="5" Background="#161B22"
                BorderBrush="#30363D" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#8B949E"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ServiceStatus}" Value="Actif">
                                        <Setter Property="Fill" Value="#3FB950"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ServiceStatus}" Value="Démarrage…">
                                        <Setter Property="Fill" Value="#D29922"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ServiceStatus}" Value="Arrêt…">
                                        <Setter Property="Fill" Value="#D29922"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ServiceStatus}" Value="Arrêté">
                                        <Setter Property="Fill" Value="#E94560"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ServiceStatus}" Value="Non installé">
                                        <Setter Property="Fill" Value="#E94560"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontSize="11" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#8B949E"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ServiceStatus}" Value="Actif">
                                        <Setter Property="Foreground" Value="#3FB950"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="Service Phase 3 : "/>
                        <Run Text="{Binding ServiceStatus}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Palier actif — centré -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#8B949E"
                               Text="{Binding PalierLabel}"/>
                    <TextBlock FontSize="11" Foreground="#6E7681" Margin="5,0,0,0"
                               Text="{Binding PalierDetail}"/>
                </StackPanel>

                <TextBlock Grid.Column="2" FontSize="11" Foreground="#8B949E"
                           VerticalAlignment="Center">
                    <Run Text="Mis à jour : "/>
                    <Run Text="{Binding LastUpdateText}"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- ── Row 6 : Bandeau bêta testeur ──────────────────────────────── -->
        <Border Grid.Row="6" Background="#1A1500" Padding="8,5"
                Visibility="{Binding IsBetaMode, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding BetaExpiryText}"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="#D29922"
                       HorizontalAlignment="Center"/>
        </Border>

    </Grid>
</Window>
